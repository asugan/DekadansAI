NODE_ENV=production
PORT=4000
TRUST_PROXY=false
CORS_ORIGIN=https://app.dekadans.net
FRONTEND_APP_URL=https://app.dekadans.net
CLI_PROXY_BASE_URL=http://host.docker.internal:8317
CLI_PROXY_API_KEY=change-me
REQUEST_TIMEOUT_MS=120000
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=https://api.dekadans.net
BETTER_AUTH_TRUSTED_ORIGINS=https://app.dekadans.net
BETTER_AUTH_DATABASE_PATH=./data/better-auth.db
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GITHUB_CLIENT_ID=change-me
GITHUB_CLIENT_SECRET=change-me
API_KEY_PREFIX=cpa_
ACCOUNT_QUOTA_WINDOW_MS=18000000
WEEKLY_QUOTA_WINDOW_MS=604800000
DEFAULT_MODEL_REQUEST_COST=1
MODEL_REQUEST_COSTS=gpt-5.5:3,kimi-k2.6:1
DEFAULT_MODEL=gpt-5.5
DEFAULT_REASONING_EFFORT=low
ACCOUNT_BURST_WINDOW_MS=20000
ACCOUNT_BURST_MAX=5
POLAR_ACCESS_TOKEN=change-me
POLAR_WEBHOOK_SECRET=change-me
POLAR_ENVIRONMENT=sandbox
# Format: productId,slug,quotaMax,weeklyQuotaMax[,label]; ... (semicolon separated)
POLAR_PLAN_TIERS=prod_weekly_500,weekly-500,500,8000,500 Request;prod_weekly_250,weekly-250,250,4000,250 Request
POLAR_CHECKOUT_SUCCESS_URL=https://app.dekadans.net/dashboard?checkout=success
POLAR_PORTAL_RETURN_URL=https://app.dekadans.net/dashboard

